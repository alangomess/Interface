interface Tributavel {
    double calculaTributos(double taxa);
}

class Conta {
    protected double saldo;
    public void deposita(double valor) { this.saldo += valor; }
}

class ContaCorrente extends Conta implements Tributavel {
    @Override
    public double calculaTributos(double taxa) {
        return (taxa / 10) * this.saldo;
    }
}

class SeguroDeVida implements Tributavel {
    private double valorSegurado = 1000.0;

    @Override
    public double calculaTributos(double taxa) {
        return (taxa * this.valorSegurado) + 10;
    }
}

class GerenciadorDeImpostoDeRenda {
    private double taxa;
    private double total;

    GerenciadorDeImpostoDeRenda(double taxa) {
        this.taxa = taxa;
    }

    void adiciona(Tributavel t) {
        System.out.println("Adicionando: " + t);
        this.total += t.calculaTributos(this.taxa);
        System.out.println("Total atual: R$ " + this.total);
    }
}

public class SistemaFinanceiro {
    public static void main(String[] args) {
        GerenciadorDeImpostoDeRenda ir = new GerenciadorDeImpostoDeRenda(0.15);

        ContaCorrente cc = new ContaCorrente();
        cc.deposita(2500);

        SeguroDeVida sv = new SeguroDeVida();

        ir.adiciona(cc);
        ir.adiciona(sv);
    }
}
